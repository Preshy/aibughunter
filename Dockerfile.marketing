FROM python:3.12-slim

WORKDIR /app

# Install dependencies
COPY pyproject.toml .
RUN pip install --no-cache-dir \
    fastapi \
    uvicorn \
    jinja2 \
    pydantic \
    pydantic-settings

# Copy application code
COPY aibughunter/ aibughunter/

# Create data directory for SQLite
RUN mkdir -p data

# Expose port
EXPOSE 8080

# Run marketing site
CMD ["python", "-m", "uvicorn", "aibughunter.web.marketing:app", "--host", "0.0.0.0", "--port", "8080"]
