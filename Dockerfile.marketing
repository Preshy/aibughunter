FROM python:3.12-slim

WORKDIR /app

# Install dependencies
RUN pip install --no-cache-dir \
    fastapi \
    uvicorn \
    pyjwt \
    pydantic \
    pydantic-settings

# Copy application code
COPY aibughunter/ aibughunter/

# Create data directory for SQLite
RUN mkdir -p data

# Expose port
EXPOSE 8080

# Run SaaS platform
CMD ["python", "-m", "uvicorn", "aibughunter.web.saas_platform:app", "--host", "0.0.0.0", "--port", "8080"]
