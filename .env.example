# AI Bug Hunter Environment Configuration
# Copy this file to .env and fill in your values

# Qwen AI API Configuration
AIBH_QWEN_API_URL=http://localhost:8080
AIBH_QWEN_API_KEY=
AIBH_QWEN_MODEL=qwen-coder-plus
AIBH_QWEN_TIMEOUT=120
AIBH_QWEN_MAX_TOKENS=8192
AIBH_QWEN_TEMPERATURE=0.3

# Scanning Configuration
AIBH_SCAN_MAX_CONCURRENT=5
AIBH_SCAN_REQUEST_TIMEOUT=30
AIBH_SCAN_RATE_LIMIT=0.1
AIBH_SCAN_MAX_DEPTH=3
AIBH_SCAN_MAX_PAGES=1000

# General Settings
AIBH_VERBOSE=false
AIBH_LOG_LEVEL=INFO
AIBH_DATA_DIR=./data
